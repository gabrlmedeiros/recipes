{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "baseUrl": "./",
    "paths": {
      "@/*": ["./*"]
    },

    "types": ["react", "react-native"]
  },
  "include": ["**/*.ts", "**/*.tsx"]
}