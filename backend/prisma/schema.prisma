generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  login     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  recipes   Recipe[]
}

model Category {
  id      String   @id @default(uuid())
  name    String   @unique @db.VarChar(100)
  recipes Recipe[]
}

model Recipe {
  id              String    @id @default(uuid())
  userId          String
  categoryId      String?
  name            String    @db.VarChar(45)
  prepTimeMinutes Int
  servings        Int
  prepMethod      String    @db.Text
  ingredients     String    @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  category        Category? @relation(fields: [categoryId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@index([categoryId], map: "Recipe_categoryId_fkey")
  @@index([userId], map: "Recipe_userId_fkey")
}

enum PrintJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model PrintJob {
  id         String         @id @default(uuid())
  recipeId   String
  status     PrintJobStatus @default(PENDING)
  filePath   String?
  error      String?        @db.Text
  requestedBy String?       
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([recipeId], map: "PrintJob_recipeId_idx")
}
