{
  "name": "a4pm-backend-nest",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:dev:with-queue": "concurrently \"npm run start:dev\" \"npm run print-worker\"",
    "start:with-queue": "npm run prisma:generate && npm run prisma:migrate:deploy || true && concurrently \"node dist/main.js\" \"node dist/scripts/print-worker.js\"",
    "print-worker": "ts-node-dev --respawn --transpile-only src/scripts/print-worker.ts",
    "worker:prod": "node dist/scripts/print-worker.js",
    "test": "jest && jest --config jest.e2e.config.ts",
    "lint": "eslint \"src/**/*.{ts,js}\" --ext .ts,.js",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest.e2e.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^5.0.0",
    "amqplib": "^0.10.3",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "concurrently": "^8.2.0",
    "cookie-parser": "^1.4.7",
    "jsonwebtoken": "^9.0.3",
    "puppeteer-core": "^24.40.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.17",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/puppeteer": "^5.4.7",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.6.0",
    "prettier": "^3.0.0",
    "prisma": "^5.22.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.9.3"
  }
}
